    "./express": {
      "types": "./dist/adapters/ui/express/index.d.ts",
      "import": "./dist/adapters/ui/express/index.js"
    },
    "./logs": {
      "types": "./dist/infrastructure/logs/index.d.ts",
      "import": "./dist/infrastructure/logs/index.js"
    },
    "./scheduler": {
      "types": "./dist/infrastructure/scheduler/index.d.ts",
      "import": "./dist/infrastructure/scheduler/index.js"
    },
    "./websocket": {
      "types": "./dist/infrastructure/websocket/index.d.ts",
      "import": "./dist/infrastructure/websocket/index.js"
    }
