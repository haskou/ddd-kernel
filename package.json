      "import": "./dist/infrastructure/dependency-injection/index.js",
      "require": "./dist/infrastructure/dependency-injection/index.cjs"
    },
    "./domain": {
      "types": "./dist/domain/index.d.ts",
      "import": "./dist/domain/index.js",
      "require": "./dist/domain/index.cjs"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "require": "./dist/errors/index.cjs"
    },
    "./express": {
      "types": "./dist/adapters/ui/express/index.d.ts",
      "import": "./dist/adapters/ui/express/index.js",
      "require": "./dist/adapters/ui/express/index.cjs"
    },
    "./lifecycle": {
      "types": "./dist/infrastructure/lifecycle/index.d.ts",
      "import": "./dist/infrastructure/lifecycle/index.js",
