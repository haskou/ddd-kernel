{
  "name": "@haskou/ddd-kernel",
  "version": "0.1.0",
  "description": "Framework-agnostic DDD kernel for TypeScript applications and microservices.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./adapters/db": {
      "types": "./dist/adapters/db/index.d.ts",
      "import": "./dist/adapters/db/index.js"
    },
    "./adapters/db/in-memory": {
      "types": "./dist/adapters/db/in-memory/index.d.ts",
      "import": "./dist/adapters/db/in-memory/index.js"
    },
