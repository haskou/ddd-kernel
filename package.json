    "./contracts/kernel": {
      "types": "./dist/contracts/kernel/index.d.ts",
      "import": "./dist/contracts/kernel/index.js"
    },
    "./contracts/pubsub": {
      "types": "./dist/contracts/pubsub/index.d.ts",
      "import": "./dist/contracts/pubsub/index.js"
    },
    "./contracts/ui": {
      "types": "./dist/contracts/ui/index.d.ts",
      "import": "./dist/contracts/ui/index.js"
    },
    "./dependency-injection": {
      "types": "./dist/infrastructure/dependency-injection/index.d.ts",
      "import": "./dist/infrastructure/dependency-injection/index.js"
    },
    "./domain": {
      "types": "./dist/domain/index.d.ts",
      "import": "./dist/domain/index.js"
