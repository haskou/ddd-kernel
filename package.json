    },
    "./adapters/pubsub/in-memory": {
      "types": "./dist/adapters/pubsub/in-memory/index.d.ts",
      "import": "./dist/adapters/pubsub/in-memory/index.js",
      "require": "./dist/adapters/pubsub/in-memory/index.cjs"
    },
    "./adapters/ui": {
      "types": "./dist/adapters/ui/index.d.ts",
      "import": "./dist/adapters/ui/index.js",
      "require": "./dist/adapters/ui/index.cjs"
    },
    "./adapters/ui/express": {
      "types": "./dist/adapters/ui/express/index.d.ts",
      "import": "./dist/adapters/ui/express/index.js",
      "require": "./dist/adapters/ui/express/index.cjs"
    },
    "./adapters/ui/routes": {
      "types": "./dist/adapters/ui/routes/index.d.ts",
      "import": "./dist/adapters/ui/routes/index.js",
      "require": "./dist/adapters/ui/routes/index.cjs"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js",
      "require": "./dist/contracts/index.cjs"
    },
    "./contracts/db": {
      "types": "./dist/contracts/db/index.d.ts",
      "import": "./dist/contracts/db/index.js",
      "require": "./dist/contracts/db/index.cjs"
    },
    "./contracts/kernel": {
      "types": "./dist/contracts/kernel/index.d.ts",
      "import": "./dist/contracts/kernel/index.js",
